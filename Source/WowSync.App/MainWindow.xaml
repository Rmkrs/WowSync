<Window x:Class="WowSync.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WowSync" Height="1030" Width="1000"
        FontFamily="Segoe UI"
        FontSize="12"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Minimal icon button for headers and grids -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>

            <!-- Force glyph rendering via a template -->
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock
                            Text="{Binding}"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="16"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="ToolTipService.ShowDuration" Value="20000"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#11000000"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#22000000"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HeaderIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   FontWeight="Normal"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CompactDataGridStyle" TargetType="{x:Type DataGrid}">
            <Setter Property="RowHeight" Value="24"/>
            <Setter Property="ColumnHeaderHeight" Value="24"/>
            <Setter Property="RowHeaderWidth" Value="0"/>

            <Setter Property="BorderBrush" Value="#FFDCDCDC"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FFE6E6E6"/>
            <Setter Property="VerticalGridLinesBrush" Value="#00FFFFFF"/>

            <Setter Property="AlternatingRowBackground" Value="#FFF8F8F8"/>

            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridCell}">
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="BorderThickness" Value="0"/>

                        <!-- Center everything in the row -->
                        <Setter Property="Padding" Value="4,0,4,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

                        <!-- Keep "no blue selection" behavior -->
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>

            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>

            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GridCellTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- title -->
            <RowDefinition Height="*"/>
            <!-- tabs -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Orientation="Vertical" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="WowSync"/>
            <TextBlock Foreground="Gray" Text="{Binding StatusLine}" Visibility="{Binding IsNotBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <TextBlock Foreground="#AA000000"
                       FontSize="11"
                       Text="{Binding BusyText}"
                       Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>

        <!-- Tabs -->
        <TabControl
            Grid.Row="1"
            SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            IsEnabled="{Binding IsNotBusy}">

            <!-- SETUP TAB -->
            <TabItem Header="Setup">
                <Grid
                    Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Paths" Grid.Row="0">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Wow root -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Wow root:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding WowRoot}" IsReadOnly="True"/>
                            <Button Grid.Row="0" Grid.Column="4" Content="Pick Wow.exe..." Width="160" Click="PickWow_Click"/>

                            <!-- Backup -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Backup folder:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding BackupRoot}" IsReadOnly="True"/>
                            <Button Grid.Row="2" Grid.Column="4" Content="Pick Backup Folder..." Width="160" Click="PickBackup_Click"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Advanced" Grid.Row="2">
                        <StackPanel Margin="8">
                            <TextBlock Foreground="Gray" FontSize="11"
                                       Text="Most changes are auto-applied. Use Rescan if you changed files outside WowSync while it is open."/>
                            <Button Content="Rescan" Width="160" Margin="0,8,0,0" Click="Rescan_Click"/>
                        </StackPanel>
                    </GroupBox>
    </Grid>
    </TabItem>

    <!-- ACCOUNTS TAB -->
    <TabItem Header="Accounts">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Discovered Accounts" VerticalAlignment="Top" MaxHeight="320">
                        <DataGrid Margin="8"
                                  VerticalAlignment="Top"
                                  Style="{StaticResource CompactDataGridStyle}"
                                  ItemsSource="{Binding Accounts}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="False"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                        >

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Use" Width="55">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding IsIncluded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      PreviewMouseLeftButtonDown="ProfileUseCheckBox_PreviewMouseLeftButtonDown"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Main" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <RadioButton GroupName="MainAccountGroup"
                                                         IsChecked="{Binding IsMain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="160" IsReadOnly="True"  ElementStyle="{StaticResource GridCellTextStyle}"/>
                                <DataGridTextColumn Header="Realms" Binding="{Binding Realms}" Width="70" IsReadOnly="True"  ElementStyle="{StaticResource GridCellTextStyle}"/>
                                <DataGridTextColumn Header="Characters" Binding="{Binding Characters}" Width="90" IsReadOnly="True"  ElementStyle="{StaticResource GridCellTextStyle}"/>
                                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" IsReadOnly="True"  ElementStyle="{StaticResource GridCellTextStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0" Header="Main toon">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ComboBox ItemsSource="{Binding MainCharacterOptions}"
                                          SelectedItem="{Binding SelectedMainCharacter, Mode=TwoWay}"
                                          DisplayMemberPath="Display"
                                          IsEnabled="{Binding IsMainCharacterPickerEnabled}"
                                          PreviewMouseDown="MainToon_UserInteraction"
                                          KeyDown="MainToon_UserInteraction_KeyDown"
                                          SelectionChanged="MainToon_SelectionChanged"/>

                        <TextBlock Grid.Row="1" Margin="0,6,0,0"
                                           Foreground="Gray" FontSize="11"
                                           Text="{Binding MainCharacterHint}"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Column="2" Header="Validation">
                    <ListView ItemsSource="{Binding ValidationLines}" Margin="8">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Severity" DisplayMemberBinding="{Binding Severity}" Width="70"/>
                                <GridViewColumn Header="Code" DisplayMemberBinding="{Binding Code}" Width="120"/>
                                <GridViewColumn Header="Message" DisplayMemberBinding="{Binding Message}" Width="380"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
            </Grid>
        </Grid>
    </TabItem>

    <!-- RUN TAB -->
    <TabItem Header="Run" Height="19" VerticalAlignment="Top">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- workbench -->
                <RowDefinition Height="Auto"/>
                <!-- run buttons -->
                <RowDefinition Height="*"/>
                <!-- output expander -->
            </Grid.RowDefinitions>

            <!-- Workbench -->
            <Grid Grid.Row="0" VerticalAlignment="Top" MaxHeight="360">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SavedVariables -->
                <GroupBox Grid.Column="0" Header="Account-wide SavedVariables">
                    <Grid Margin="8">
                                <DataGrid Style="{StaticResource CompactDataGridStyle}" ItemsSource="{Binding AccountSvRows}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          SelectionUnit="Cell"
                                          SelectionMode="Single"
                                          MinHeight="120"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">

                            <DataGrid.Columns>
                                <!-- Use -->
                                <DataGridTemplateColumn Header="Use" Width="55">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Focusable="False"
                                                      IsChecked="{Binding IsIncluded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      PreviewMouseLeftButtonDown="ProfileUseCheckBox_PreviewMouseLeftButtonDown"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- File -->
                                <DataGridTemplateColumn Header="File" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FileName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellTextStyle}">
                                                        <Setter Property="Foreground" Value="Red"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Exists}" Value="True">
                                                                <Setter Property="Foreground" Value="Green"/>
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding IsIncluded}" Value="False">
                                                                <Setter Property="Opacity" Value="0.5"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Width="36">

                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <Grid
                                                HorizontalAlignment="Stretch"
                                                Width="{Binding RelativeSource={RelativeSource AncestorType=DataGridColumnHeader}, Path=ActualWidth}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="1"
                                                        Style="{StaticResource HeaderIconButtonStyle}"
                                                        Content="&#xECC8;"
                                                        Margin="0,0,4,0"
                                                        Click="AddAccountSvFile_Click"
                                                        IsEnabled="{Binding CanAddAccountSvFile}"
                                                        ToolTip="Add a SavedVariables file that will be copied verbatim from the main account to included accounts.&#x0a;No parsing. No profiles. No character matching."/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>

                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource IconButtonStyle}"
                                                            Content="&#xE74D;"
                                                            HorizontalAlignment="Right"
                                                            Click="DeleteAccountSvFile_Click"
                                                            Tag="{Binding}"
                                                            ToolTip="Remove this file from WowSync configuration.&#x0a;This does not delete anything from disk."/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>

                <!-- Per-toon sync -->
                <GroupBox Grid.Column="2" Header="Per-toon sync">
                    <Grid Margin="8">
                                <DataGrid Style="{StaticResource CompactDataGridStyle}" ItemsSource="{Binding ProfileRows}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          SelectionUnit="Cell"
                                          SelectionMode="Single"
                                          MinHeight="160"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">

                                    <DataGrid.RowStyle>
                                        <Style TargetType="{x:Type DataGridRow}">
                                            <EventSetter Event="MouseDoubleClick" Handler="ProfilesGridRow_MouseDoubleClick"/>
                                        </Style>
                                    </DataGrid.RowStyle>

                                    <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Use" Width="55">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Focusable="False"
                                                              IsChecked="{Binding IsIncluded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              PreviewMouseLeftButtonDown="ProfileUseCheckBox_PreviewMouseLeftButtonDown"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Profile"
                                                            Binding="{Binding FileName}"
                                                            IsReadOnly="True"
                                                            Width="2*"
                                                            ElementStyle="{StaticResource GridCellTextStyle}"/>

                                <!-- Lua star-sized to prevent horizontal scrollbar -->
                                <DataGridTemplateColumn Header="Lua" Width="2*" MinWidth="180" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LuaFileName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridCellTextStyle}">
                                                        <Setter Property="Foreground" Value="Red"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LuaExists}" Value="True">
                                                                <Setter Property="Foreground" Value="Green"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="96">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <Grid
                                                HorizontalAlignment="Stretch"
                                                Width="{Binding RelativeSource={RelativeSource AncestorType=DataGridColumnHeader}, Path=ActualWidth}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="1"
                                                        Style="{StaticResource HeaderIconButtonStyle}"
                                                        Content="&#xECC8;"
                                                        Margin="0,0,4,0"
                                                        Click="LuaInspector_Click"
                                                        ToolTip="Create profile: open Lua Inspector to select branches, then Save to create the profile."/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>

                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center">
                                                        <Button Style="{StaticResource IconButtonStyle}"
                                                                Content="&#xE8A7;"
                                                                ToolTip="Open in Lua Inspector"
                                                                Click="OpenProfileInInspector_Click"
                                                                Tag="{Binding}"/>
                                                <Button Style="{StaticResource IconButtonStyle}"
                                                                Content="&#xE8AC;"
                                                                ToolTip="Rename profile"
                                                                Click="RenameProfile_Click"
                                                                Tag="{Binding}"/>
                                                <Button Style="{StaticResource IconButtonStyle}"
                                                                Content="&#xE74D;"
                                                                ToolTip="Remove this profile from WowSync configuration.&#x0a;This does not delete anything from disk."
                                                                Click="DeleteProfile_Click"
                                                                Tag="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>

                <!-- Plugins -->
                <GroupBox Grid.Column="4" Header="Plugins">
                    <Grid Margin="8">
                                <DataGrid Style="{StaticResource CompactDataGridStyle}" ItemsSource="{Binding PluginRows}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          SelectionUnit="Cell"
                                          SelectionMode="Single"
                                          MinHeight="160"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Use" Width="55">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Focusable="False"
                                                              IsChecked="{Binding IsIncluded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              PreviewMouseLeftButtonDown="ProfileUseCheckBox_PreviewMouseLeftButtonDown"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Plugin" Binding="{Binding DisplayName}" Width="220" IsReadOnly="True"  ElementStyle="{StaticResource GridCellTextStyle}"/>
                                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" IsReadOnly="True"  ElementStyle="{StaticResource GridCellTextStyle}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </GroupBox>
            </Grid>

            <!-- Run buttons -->
            <GroupBox Grid.Row="1" Header="Run" Margin="0,10,0,0">
                <DockPanel Margin="8" LastChildFill="False">
                    <!-- Left: buttons -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="Refresh" Width="90" Margin="0,0,8,0" Click="RefreshProfiles_Click"
                                IsEnabled="{Binding IsNotBusy}"/>
                        <Button Content="Dry Run" Width="140" Margin="0,0,8,0" Click="DryRunSync_Click"
                                IsEnabled="{Binding IsNotBusy}"/>
                        <Button Content="Apply" Width="140" Margin="0,0,8,0" Click="ApplySync_Click"
                                IsEnabled="{Binding IsNotBusy}"/>
                        <Button Content="Undo" Width="140" Click="UndoLastApply_Click"
                                IsEnabled="{Binding CanUndoLastApply}"/>
                    </StackPanel>

                    <!-- Right: scope -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                        <TextBlock Text="Scope:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Width="260"
                                  ItemsSource="{Binding SyncScopes}"
                                  SelectedItem="{Binding SelectedSyncScope, Mode=TwoWay}"
                                  SelectionChanged="SyncScope_SelectionChanged"
                                  IsEnabled="{Binding IsNotBusy}"/>
                    </StackPanel>
                </DockPanel>
            </GroupBox>

            <!-- Output -->
            <Expander Grid.Row="2"
                              Margin="0,10,0,0"
                              Header="Run output"
                              IsExpanded="{Binding IsRunOutputExpanded, Mode=TwoWay}">
                <Grid Margin="8">
                    <TextBox Text="{Binding RunOutputText}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"
                                     IsReadOnlyCaretVisible="True"
                                     MinHeight="220"/>
                </Grid>
            </Expander>
        </Grid>
    </TabItem>
    </TabControl>
    </Grid>
</Window>
