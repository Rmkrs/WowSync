<Window x:Class="WowSync.App.LuaInspector.LuaInspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lua Inspector" Height="720" Width="1500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="True">
            <Button Content="Open .lua..." Width="120" Margin="0,0,8,0" Click="Open_Click"/>

            <TextBlock Text="File:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding FilePath}" IsReadOnly="True" Width="520" Margin="0,0,12,0"/>

            <TextBlock Text="Global:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding GlobalName}" IsReadOnly="True" Width="220" Margin="0,0,12,0"/>

            <!-- Search -->
            <TextBlock Text="Find:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Width="220"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="SearchBox_KeyDown"
                     Margin="0,0,8,0"/>

            <Button Content="Find next" Width="90" Click="FindNext_Click" Margin="0,0,8,0"/>

            <TextBlock Text="{Binding SearchStatus}" Opacity="0.7" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Main area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Tree -->
            <GroupBox Header="AST" Grid.Column="0" Margin="0,0,8,0">
                <Grid>
                    <TreeView x:Name="AstTree"
                              ItemsSource="{Binding Nodes}"
                              SelectedItemChanged="Tree_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Text=" = " Opacity="0.6" />
                                    <TextBlock Text="{Binding DisplayValue}" Opacity="0.8" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </GroupBox>

            <!-- Details + Profile -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Header="Selected Node" Grid.Row="0" Margin="0,0,0,8">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Path:" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding SelectedPath}" IsReadOnly="True"/>
                        <Button Grid.Column="2" Content="Copy Path" Margin="8,0,0,0" Click="CopyPath_Click"/>

                        <TextBlock Grid.Row="1" Text="Value:" Margin="0,8,8,0" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedValue}" IsReadOnly="True" Margin="0,8,0,0"/>

                        <Button Grid.Row="2" Grid.Column="1" Content="Add Path to Profile" Margin="0,8,0,0" HorizontalAlignment="Left" Width="160" Click="AddPath_Click"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Profile Builder" Grid.Row="1">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Profile name:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding ProfileName}"
                                 IsReadOnly="{Binding IsEditingExistingProfile}"
                                 Margin="0,0,0,6">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditingExistingProfile}" Value="True">
                                            <Setter Property="Background" Value="#FFF2F2F2"/>
                                            <Setter Property="Foreground" Value="#FF666666"/>
                                            <Setter Property="BorderBrush" Value="#FFBDBDBD"/>
                                            <Setter Property="Cursor" Value="Arrow"/>
                                            <Setter Property="ToolTip" Value="Editing existing profile (name locked)"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Grid.Row="1" Text="File name:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Text="{Binding ProfileFileName}"
                                 IsReadOnly="True"
                                 Margin="0,0,0,8"
                                 Background="#FFF8F8F8"
                                 Foreground="#FF555555"
                                 BorderBrush="#FFCCCCCC"/>

                        <TextBlock Grid.Row="2"
                                   Text="Patch mode:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <ComboBox Grid.Row="2"
                                  Grid.Column="1"
                                  ItemsSource="{Binding PatchModeOptions}"
                                  SelectedItem="{Binding ProfilePatchMode, Mode=TwoWay}"
                                  Margin="0,0,0,8"/>

                        <ListBox Grid.Row="3" Grid.ColumnSpan="3" ItemsSource="{Binding IncludePaths}"/>

                        <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="Remove Selected" Width="140" Margin="0,0,8,0" Click="RemoveSelected_Click"/>
                            <Button Content="Save Profile" Width="120" Click="SaveProfile_Click"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>

        <!-- Bottom -->
        <Border Grid.Row="2" Margin="0,8,0,0" Padding="8" CornerRadius="6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFEFF6FF"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                            <Setter Property="Background" Value="#FFFFEEEE"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}" Opacity="0.9"/>
        </Border>
    </Grid>
</Window>
